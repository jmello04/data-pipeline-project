# ─────────────────────────────────────────────────────────────────
#  .env.example  –  copy to .env and fill in every value
#  NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────

# ── Paths ──────────────────────────────────────────────────────
RAW_DATA_PATH=data/raw
PROCESSED_DATA_PATH=data/processed
ANALYTICS_DATA_PATH=data/analytics
LOGS_PATH=logs

# ── Synthetic data ──────────────────────────────────────────────
NUM_CUSTOMERS=1000
NUM_PRODUCTS=200
NUM_ORDERS=5000
FAKE_DATA_SEED=42

# ── Data quality ────────────────────────────────────────────────
NULL_THRESHOLD=0.10

# ── LGPD anonymisation ──────────────────────────────────────────
# REQUIRED: random string of ≥32 characters used as HMAC key.
# Plain SHA-256 is vulnerable to rainbow tables; HMAC-SHA256 is not.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
LGPD_HASH_KEY=replace-with-a-real-secret-minimum-32-chars

# ── Streaming / Kafka ───────────────────────────────────────────
USE_REAL_KAFKA=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=orders_stream
KAFKA_GROUP_ID=pipeline_consumer
STREAMING_INTERVAL_SEC=0.1
STREAMING_NUM_EVENTS=50

# ── Spark ───────────────────────────────────────────────────────
SPARK_APP_NAME=DataPipelineProject
SPARK_MASTER=local[*]
